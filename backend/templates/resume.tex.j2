    ignoreheadfoot, top=2 cm, bottom=2 cm,
    left=2 cm, right=2 cm, footskip=1.0 cm,
]{geometry}
\usepackage{titlesec}
\usepackage{tabularx}
\usepackage{array}
\usepackage[dvipsnames]{xcolor}
\definecolor{primaryColor}{RGB}{0, 0, 0}
\usepackage{enumitem}
\usepackage{fontawesome5}
\usepackage{amsmath}
\usepackage[
    pdftitle={Resume},
    pdfauthor={Resume},
    pdfcreator={LaTeX with Tectonic},
    colorlinks=true,
    urlcolor=primaryColor
]{hyperref}
\usepackage[pscoord]{eso-pic}
\usepackage{calc}
\usepackage{bookmark}
\usepackage{lastpage}
\usepackage{changepage}
\usepackage{paracol}
\usepackage{ifthen}
\usepackage{needspace}
\usepackage{iftex}
\ifPDFTeX
    \input{glyphtounicode}
    \pdfgentounicode=1
    \usepackage[T1]{fontenc}
    \usepackage[utf8]{inputenc}
    \usepackage{lmodern}
\fi
\usepackage{charter}
\raggedright
\AtBeginEnvironment{adjustwidth}{\partopsep0pt}
\pagestyle{empty}
\setcounter{secnumdepth}{0}
\setlength{\parindent}{0pt}
\setlength{\topskip}{0pt}
\setlength{\columnsep}{0.15cm}
\pagenumbering{gobble}
\titleformat{\section}{
  \needspace{4\baselineskip}\bfseries\large
}{}{0pt}{}[\vspace{1pt}\titlerule]
\titlespacing{\section}{-1pt}{0.3 cm}{0.2 cm}
\renewcommand\labelitemi{$\vcenter{\hbox{\small$\bullet$}}$}

% Define custom environments exactly as in original
\newenvironment{highlights}{
  \begin{itemize}[leftmargin=0cm, label={}]
}{
  \end{itemize}
}

\newenvironment{highlightsforbulletentries}{
  \begin{itemize}[leftmargin=0.5cm]
}{
  \end{itemize}
}

\newenvironment{onecolentry}{
  \begin{adjustwidth}{0pt}{0pt}
}{
  \end{adjustwidth}
}

\newenvironment{twocolentry}[1]{
  \begin{minipage}[t]{0.15\linewidth}
  #1
  \end{minipage}
  \begin{minipage}[t]{0.83\linewidth}
}{
  \end{minipage}
}

\newenvironment{threecolentry}[1]{
  \begin{minipage}[t]{0.10\linewidth}
  #1
  \end{minipage}
  \begin{minipage}[t]{0.30\linewidth}
}{
  \end{minipage}
}

\newcommand{\AND}{
  \enspace\smash{\vrule height 0.75ex depth -0.5ex width 0.4pt}\enspace
}

\newcommand{\hrefWithoutArrow}[2]{
  \href{#1}{#2}
}
{% endraw %}

\begin{document}

  % HEADER
  \begin{center}
    \fontsize{25pt}{25pt}\selectfont {{ header.name | latex_escape }}
    \vspace{5pt}
    \normalsize
    \kern 5.0pt
    \mbox{\hrefWithoutArrow{mailto:{{ header.email | latex_escape }}}{ {{- header.email | latex_escape -}} }}
    \kern 5.0pt \AND \kern 5.0pt
    \mbox{\hrefWithoutArrow{https://wa.me/{{ header.phone | latex_escape }}}{ {{- header.phone | latex_escape -}} }}
    \kern 5.0pt \AND \kern 5.0pt
    \mbox{\hrefWithoutArrow{ {{- header.linkedin | latex_escape -}} }{linkedin}}
    \kern 5.0pt \AND \kern 5.0pt
    \mbox{\hrefWithoutArrow{ {{- header.github | latex_escape -}} }{github}}
  \end{center}

  \vspace{5pt - 0.3cm}

   % SUMMARY
    \section{Summary}
    \begin{onecolentry}
      {{ summary | latex_escape }}
    \end{onecolentry}

  % EDUCATION
  \section{Education}
  {% for edu in education %}
  \begin{twocolentry}{ {{ edu.duration | latex_escape }} }
    \textbf{ {{ edu.institution | latex_escape }} } -- {{ edu.degree | latex_escape }}
  \end{twocolentry}
    \vspace{0.2cm}
  {% endfor %}

  % PROJECTS
  \section{Projects}
  {% for project in projects %}
  \vspace{0.2cm}
  \begin{twocolentry}{ {{ project.duration | latex_escape }} }
    \textbf{\href{ {{ project.url | latex_escape }} }{ {{ project.name | latex_escape }} }}
  \end{twocolentry}
    \begin{onecolentry}
      \begin{highlights}
        {% for bullet in project.bullets %}
        \item {{ bullet | latex_escape }}
        {% endfor %}
      \end{highlights}
    \end{onecolentry}
  {% endfor %}

  % INTERNSHIP
  \section{Internship}
  {% for exp in internship %}
  \begin{twocolentry}{ {{ exp.duration | latex_escape }} }
    \textbf{\href{ {{ exp.url | latex_escape }} }{ {{ exp.company | latex_escape }} }}
    -- {{ exp.role | latex_escape }}
  \end{twocolentry}
    \vspace{0.10cm}
    \begin{onecolentry}
      \begin{highlights}
        {% for bullet in exp.bullets %}
        \item {{ bullet | latex_escape }}
        {% endfor %}
      \end{highlights}
    \end{onecolentry}
  {% endfor %}

  % SKILLS
  \section{Skills}
  {% for skill in skills %}
  \begin{onecolentry}
    \textbf{ {{ skill['category'] | latex_escape }}: } {{ skill['items'] | latex_escape }}
  \end{onecolentry}
    \vspace{0.2cm}
  {% endfor %}

  % CERTIFICATIONS
  \section{Certifications}
  \begin{highlights}
    {% for cert in certifications %}
    \item \href{ {{ cert.url | latex_escape }} }{ {{ cert.name | latex_escape }} }
      ({{ cert.duration | latex_escape }})
    {% endfor %}
  \end{highlights}

\end{document}